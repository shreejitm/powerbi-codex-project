		    // #"Staffing Entitlement 2025 - Ko Taku Reo - Deaf Education New Zealand - 17-07-2025 xlsx_https://kotakureo sharepoint com/sites/PMOActivity/Shared Documents/General/PowerBI/Testing/Staffing Entitlement/" = #"Filtered Rows"{[Name="Staffing Entitlement 2025 - Ko Taku Reo - Deaf Education New Zealand - 17-07-2025.xlsx",#"Folder Path"="https://kotakureo.sharepoint.com/sites/PMOActivity/Shared Documents/General/PowerBI/Data Source External/Ministry_staffing_Pourato/"]}[Content],
		    // #"Imported Excel Workbook" = Excel.Workbook(#"Staffing Entitlement 2025 - Ko Taku Reo - Deaf Education New Zealand - 17-07-2025 xlsx_https://kotakureo sharepoint com/sites/PMOActivity/Shared Documents/General/PowerBI/Testing/Staffing Entitlement/"),
		    // #"Your Entitlement 2025_Sheet" = #"Imported Excel Workbook"{[Item="Your Entitlement 2025",Kind="Sheet"]}[Data],
		    Custom1 = Table.Skip(InputTable, each [Column4] = null),
		    #"Promoted Headers" = Table.PromoteHeaders(Custom1, [PromoteAllScalars=true]),
		    Custom2 = Table.ColumnNames( #"Promoted Headers"),
		    Custom3 = {"Column1"}&{"Column2"}&{"Column3"} &List.Select(Custom2, each Text.Contains(_, "Pay Period")),
		    Custom4 = Table.SelectColumns(#"Promoted Headers", Custom3),
		    #"Unpivoted Other Columns" = Table.UnpivotOtherColumns(Custom4, {"Column1", "Column2", "Column3"}, "Attribute", "Value"),
		    #"Filtered Rows1" = Table.SelectRows(#"Unpivoted Other Columns", each ([Column1] <> "Component")),
