expression CleanUpData =
		let
		    Source = (InputTable as table)=>
		let
		    Source = SharePoint.Files(Source, [ApiVersion = 15]),
		    #"Filtered Rows" = Table.SelectRows(Source, each ([Folder Path] = "https://kotakureo.sharepoint.com/sites/Pay/PayrollGuidance/Reports - Online Portal/Purato/")),
		    #"Staffing Entitlement 2025 - Ko Taku Reo - Deaf Education New Zealand - 31-07-2025 xlsx_https://kotakureo sharepoint com/sites/Pay/PayrollGuidance/Reports - Online Portal/Purato/" = #"Filtered Rows"{[Name="Staffing Entitlement 2025 - Ko Taku Reo - Deaf Education New Zealand - 31-07-2025.xlsx",#"Folder Path"="https://kotakureo.sharepoint.com/sites/Pay/PayrollGuidance/Reports - Online Portal/Purato/"]}[Content],
		    #"Imported Excel Workbook" = Excel.Workbook(#"Staffing Entitlement 2025 - Ko Taku Reo - Deaf Education New Zealand - 31-07-2025 xlsx_https://kotakureo sharepoint com/sites/Pay/PayrollGuidance/Reports - Online Portal/Purato/"),
		    #"Your Entitlement 2025_Sheet" = #"Imported Excel Workbook"{[Item="Your Entitlement 2025",Kind="Sheet"]}[Data],
		    Custom1 = Table.Skip(InputTable, each [Column4] = null),
		    // Custom1 = Table.Skip(#"Your Entitlement 2025_Sheet", each [Column4] = null),
		    #"Promoted Headers" = Table.PromoteHeaders(Custom1, [PromoteAllScalars=true]),
		    Custom3 = Table.SelectColumns(
		    #"Promoted Headers",
		    {"Column1"} & {"Column2"}  & {"Column3"}  & List.Select(
		        Table.ColumnNames(#"Promoted Headers"),
		        each Text.Contains(_, "Pay Period")
		    )
		),
		    #"Unpivoted Other Columns" = Table.UnpivotOtherColumns(Custom3, {"Column1", "Column2", "Column3"}, "Attribute", "Value"),
		    #"Filtered Rows1" = Table.SelectRows(#"Unpivoted Other Columns", each ([Column1] <> "Component"  and [Column1] <> "Total")),
		    #"Replaced Value" = Table.ReplaceValue(#"Filtered Rows1",">",null,Replacer.ReplaceValue,{"Column1"}),
		    #"Filled Down" = Table.FillDown(#"Replaced Value",{"Column1"}),
		    #"Renamed Columns1" = Table.RenameColumns(#"Filled Down",{{"Column1", "Title1"}, {"Column2", "Title2"}, {"Column3", "Title3"}, {"Attribute", "Pay Period"}}),
		    #"Replaced Value1" = Table.ReplaceValue(#"Renamed Columns1",">>",null,Replacer.ReplaceValue,{"Title2"}),
		    #"Changed Type" = Table.TransformColumnTypes(#"Replaced Value1",{{"Value", type number}}),
		    #"Inserted Merged Column" = Table.AddColumn(#"Changed Type", "Merged", each Text.Combine({[Title1], [Title2], [Title3]}, "-"), type text)
		in
		    #"Inserted Merged Column"
		in
		    Source
