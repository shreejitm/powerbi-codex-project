		    #"Replaced Value1" = Table.ReplaceValue(#"Replaced Value",">>",null,Replacer.ReplaceValue,{"Column2"}),
		    #"Filled Down" = Table.FillDown(#"Replaced Value1",{"Column1"}),
		    Custom5 = Table.SelectRows(#"Filled Down", each not (
		        [Column1] <> null and [Column2] = null and [Column3] = null)),
		    #"Filled Down1" = Table.FillDown(#"Custom5",{"Column2"})
		in
		    #"Filled Down1"
